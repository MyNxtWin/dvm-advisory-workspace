# ─────────────────────────────────────────────
# DVM Advisory Workspace — Environment Variables
# Copy this file to .env and fill in all values.
# Never commit .env to git.
# ─────────────────────────────────────────────

# ── ANTHROPIC ──────────────────────────────────
# Get from: console.anthropic.com → API Keys
ANTHROPIC_API_KEY=sk-ant-

# ── RESEND (OTP email delivery) ────────────────
# Get from: resend.com → API Keys (free: 3,000 emails/month)
RESEND_API_KEY=re_

# Sender shown in the OTP email. Must be a domain you've verified in Resend.
# Format: Display Name <email@yourdomain.com>
FROM_EMAIL=DVM Advisory <noreply@yourdomain.com>

# ── AUTH & SECURITY ────────────────────────────
# Random secret used to sign OTP tokens and session tokens.
# Generate with: openssl rand -hex 32
# Changing this invalidates all active sessions.
OTP_SECRET=

# Comma-separated list of email domains allowed to log in.
# Example: mynxtwin.com,partnerfirm.com
ALLOWED_DOMAINS=

# Comma-separated list of emails with admin panel access.
# Example: technology@mynxtwin.com,sridhar@mynxtwin.com
ADMIN_EMAILS=

# ── GITHUB CMS (agent storage) ─────────────────
# The admin panel saves agents to data/agents.json in your GitHub repo.
# Every save triggers a Netlify rebuild (1-3 min) — agents go live after that.
#
# GITHUB_TOKEN: Create at github.com → Settings → Developer settings →
#               Personal access tokens → Fine-grained tokens
#               Permissions needed: Contents (read + write) on this repo only
# GITHUB_OWNER: Your GitHub username or org name
# GITHUB_REPO:  The repo name (e.g. dvm-advisory-workspace)
# AGENTS_FILE_PATH: Path to the agents file in the repo (don't change this)
GITHUB_TOKEN=github_pat_
GITHUB_OWNER=
GITHUB_REPO=
AGENTS_FILE_PATH=data/agents.json

# ── DEPLOYMENT ─────────────────────────────────
# Your Netlify site URL — used to lock CORS to your domain only.
# Leave blank for local dev. Set in Netlify dashboard for production.
# Example: https://dvm-advisory.netlify.app
SITE_URL=
